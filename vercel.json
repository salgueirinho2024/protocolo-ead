    { "source": "/api/empresa/certificados", "destination": "/api/empresa/funcionarios?sub=certificados" },
    { "source": "/api/empresa/estatisticas", "destination": "/api/empresa/funcionarios?sub=estatisticas" },
    { "source": "/api/empresa/perfil", "destination": "/api/empresa/funcionarios?sub=perfil" },
