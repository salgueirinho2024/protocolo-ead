# Copie este arquivo para .env e preencha com seus valores reais.
# NUNCA suba o arquivo .env para o GitHub (ele já está no .gitignore).

# String de conexão do PostgreSQL (Neon, Railway, Supabase, etc.)
DATABASE_URL=postgresql://usuario:senha@host/banco

# Chave secreta usada para assinar os tokens de login (JWT).
# Troque por um valor longo e aleatório antes de ir para produção.
JWT_SECRET=troque-esta-chave-por-algo-bem-aleatorio-e-secreto

# development | production
# Na Vercel, defina NODE_ENV=production nas variáveis de ambiente do projeto.
NODE_ENV=development

# URL pública onde o backend vai ficar acessível (sem barra no final).
# Usada para montar o link de validação do certificado e o link do PDF.
# Em desenvolvimento local (rodando com `vercel dev`):
APP_URL=http://localhost:3000

# Em produção, depois que a Vercel gerar o domínio do projeto:
# APP_URL=https://seu-projeto.vercel.app

# Lista de origens (frontends) autorizadas a chamar a API, separadas por vírgula.
# Deixe em branco/remova para liberar geral (não recomendado em produção).
# ALLOWED_ORIGINS=https://seu-frontend.vercel.app,http://localhost:5500
